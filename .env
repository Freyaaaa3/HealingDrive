# ==================== 大模型调度配置（Module 10）====================
# 所有API Key在此集中管理，缺失不报错，仅使用时提示

# 本地 Ollama 服务地址（无需Key）
VITE_OLLAMA_BASE_URL=http://localhost:11434

# API 模型密钥（可选，不填不报错，使用时提示）
VITE_OPENAI_API_KEY=
VITE_DEEPSEEK_API_KEY=
VITE_DOUBAO_API_KEY=
VITE_QWEN_API_KEY=
VITE_MOONSHOT_API_KEY=
VITE_ANTHROPIC_API_KEY=

# ==================== 语音识别（ASR）配置 ====================
# local      → 本地离线 Vosk ASR（推荐，国内可用，需启动 Python 服务）
# iflytek    → 讯飞流式听写（国内可用，需配置下方 VITE_IFLYTEK_* 凭据）
# 留空       → 浏览器 Web Speech API（需 Google 服务）
VITE_ASR_PROVIDER=local
# Local ASR WebSocket 服务地址（VITE_ASR_PROVIDER=local 时使用）
VITE_ASR_WS_URL=ws://127.0.0.1:5124
# 讯飞流式听写凭据（VITE_ASR_PROVIDER=iflytek 时必填）
VITE_IFLYTEK_APP_ID=
VITE_IFLYTEK_API_KEY=
VITE_IFLYTEK_API_SECRET=

# ==================== 语音合成（TTS）配置 ====================
# browser → 浏览器 SpeechSynthesis
# http    → HTTP 服务（需启动 Python 服务，推荐）
VITE_TTS_MODE=http
# TTS HTTP 服务地址
VITE_TTS_HTTP_URL=http://127.0.0.1:5123
# TTS 默认音色
VITE_TTS_EDGE_VOICE=zh-CN-XiaoxiaoNeural
